# Root .env for the Docker Compose production stack (docker-compose.yml).
# Copy this file to .env and fill in real values, then `docker compose up -d`
# is the only action needed on the target server. .env itself is gitignored
# and must never be committed.
#
# This is separate from backend/.env (used for local dev without Docker) -
# Compose passes these values into the backend container as environment
# variables directly, backend/.env is not read inside the container.

# --- Domain & HTTPS (Caddyfile) ---
# The public domain this site will be reachable at. Leave as "localhost" to
# test the whole stack locally (Caddy then uses a self-signed certificate).
# A real domain here gets a genuine Let's Encrypt certificate automatically.
DOMAIN=localhost
# Contact address for Let's Encrypt expiry notices. Optional but recommended
# once DOMAIN is a real public domain.
ACME_EMAIL=admin@example.com

# --- Database (db service) ---
POSTGRES_DB=punishers
POSTGRES_USER=punishers
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# --- Django / JWT / encryption (backend service) ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Optional one-time admin bootstrap ---
# If all three are set and no superuser exists yet, one is created
# automatically on first container start (see backend/docker-entrypoint.sh) -
# so the target server needs no shell access to get its first admin account.
# Leave empty to create the first superuser yourself later via
# `docker compose exec backend python manage.py createsuperuser`.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# --- Optional integrations (all gracefully skipped/disabled if left empty) ---
FACEIT_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Punishers Germany <no-reply@example.com>

# Note: LIBRETRANSLATE_URL is not listed here - docker-compose.yml always
# points the backend at the bundled libretranslate service automatically.
