# Root .env for the Docker Compose production stack (docker-compose.yml).
# Copy this file to .env and fill in real values, then `docker compose up -d`
# is the only action needed on the target server. .env itself is gitignored
# and must never be committed.
#
# This is separate from backend/.env (used for local dev without Docker) -
# Compose passes these values into the backend container as environment
# variables directly, backend/.env is not read inside the container.

# --- Domain (used for BACKEND_BASE_URL/FRONTEND_BASE_URL/CORS_ORIGINS) ---
# The public domain this site will be reachable at. Leave as "localhost" for
# local testing. In production this is set to the real domain
# (e.g. punishersgermany.de) - HTTPS/routing itself is handled by whatever
# reverse proxy already owns the host's ports 80/443, see README
# "Produktion mit Docker" for the join-an-existing-proxy deployment runbook.
DOMAIN=localhost
# Name of the external Docker network the existing reverse proxy's containers
# use, so `backend`/`frontend` can attach to it and be reachable by service
# name. Only relevant in production - irrelevant for local testing.
SHARED_NETWORK_NAME=goalkeeper_prod_network

# --- Database (db service) ---
POSTGRES_DB=punishers
POSTGRES_USER=punishers
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# --- Django / JWT / encryption (backend service) ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Optional one-time admin bootstrap ---
# If all three are set and no superuser exists yet, one is created
# automatically on first container start (see backend/docker-entrypoint.sh) -
# so the target server needs no shell access to get its first admin account.
# Leave empty to create the first superuser yourself later via
# `docker compose exec backend python manage.py createsuperuser`.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# --- Optional integrations (all gracefully skipped/disabled if left empty) ---
FACEIT_API_KEY=
FACEIT_DEFAULT_GAME_ID=cs2
# Minutes between automatic FACEIT syncs; 0 disables the scheduler entirely.
FACEIT_SYNC_INTERVAL_MINUTES=180
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Minutes between checks for a creator going live (drives Discord "stream
# live" announcements, see REDIS_HOST below); 0 disables the poller.
TWITCH_LIVE_POLL_INTERVAL_MINUTES=5
YOUTUBE_API_KEY=
# Redis bridge to the org's Discord bot - a separate deployment
# (bot-plattform repo), reachable only via Redis pub/sub. Defaults assume
# that deployment's `redis` container is reachable on the shared
# goalkeeper_prod_network this stack already joins - see docker-compose.yml.
REDIS_HOST=redis
REDIS_PORT=6379
# How often (minutes) Join-to-Create voice triggers and the rule-acceptance
# reaction-role get re-pushed to the bot, so it converges after a restart
# even without a dashboard save (Redis pub/sub has no replay). 0 disables it.
DISCORD_CONFIG_SYNC_INTERVAL_MINUTES=5
# Transactional email (account-activated / password-reset). Leave EMAIL_HOST
# empty to just log emails to the server console instead of sending them.
# Any SMTP provider works - e.g. Brevo's free tier (300 emails/day):
#   1. Sign up at https://www.brevo.com/, verify the sender domain
#      (punishersgermany.de) via the SPF/DKIM DNS records Brevo gives you.
#   2. Settings -> SMTP & API -> SMTP -> create SMTP credentials.
#   3. EMAIL_HOST=smtp-relay.brevo.com, EMAIL_PORT=587, EMAIL_HOST_USER/
#      EMAIL_HOST_PASSWORD from step 2.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Punishers Germany <no-reply@example.com>

# Note: LIBRETRANSLATE_URL is not listed here - docker-compose.yml always
# points the backend at the bundled libretranslate service automatically.
