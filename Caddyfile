# Reverse proxy + automatic HTTPS. `DOMAIN=localhost` (the default, see
# .env.example) makes Caddy use its own internal/self-signed certificate for
# local testing; a real public domain gets a genuine Let's Encrypt
# certificate provisioned and renewed automatically - no certbot, no cron
# job, no extra plugins needed.

{
	email {$ACME_EMAIL:admin@localhost}
}

{$DOMAIN:localhost} {
	# Everything under /api/* goes to the backend, with the prefix
	# stripped before forwarding - so none of the FastAPI routes
	# (fastapi_app/main.py) need to know about or be renamed for this
	# prefix. VITE_API_BASE_URL is set to the relative "/api" (see
	# frontend/.env.production) to match.
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
