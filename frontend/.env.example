# Copy to .env.development / .env.production (or .env.local) as needed.
# Vite only exposes variables prefixed with VITE_ to client code.

# Base URL of the FastAPI backend.
VITE_API_BASE_URL=http://localhost:8000

# When "true": use obvious placeholder images/sponsor logos everywhere so the
# site is fully browsable without any real assets (useful for local dev and
# screenshots). When "false": use the real production assets/sponsor list
# (see app/lib/sampleAssets.ts) and fall back to a neutral "no image" graphic
# where no real asset exists yet.
VITE_USE_SAMPLE_ASSETS=true
