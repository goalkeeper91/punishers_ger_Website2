# Copy this file to .env and fill in real values. .env itself is gitignored
# and must never be committed.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- FastAPI / API layer ---
# Public URL the FastAPI app is reachable at (used to build absolute media URLs).
BACKEND_BASE_URL=http://localhost:8000
# Comma-separated list of origins allowed to call the API from the browser.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- JWT auth ---
# Falls back to DJANGO_SECRET_KEY if unset. Set a distinct value in production
# so the two secrets can be rotated independently.
JWT_SECRET_KEY=change-me-to-a-different-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Encrypts stored OAuth tokens at rest (social_stats.TwitchAuthorization -
# see social_stats/crypto.py). Falls back to a key derived from
# DJANGO_SECRET_KEY if unset; set explicitly in production (generate with
# `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`)
# so rotating DJANGO_SECRET_KEY doesn't break decryption of stored tokens.
ENCRYPTION_KEY=

# --- FACEIT integration (faceit_integration app) ---
# Server-side API key from https://developers.faceit.com/. Leave empty to
# disable syncing entirely (sync calls will fail with a clear error instead
# of crashing).
FACEIT_API_KEY=
# FACEIT game ID used for player stats lookups.
FACEIT_DEFAULT_GAME_ID=cs2
# How often the in-process scheduler auto-syncs, in minutes. Set to 0 to
# disable automatic syncing (manual trigger / `manage.py sync_faceit` still work).
FACEIT_SYNC_INTERVAL_MINUTES=180

# --- Twitch integration (twitch_integration app) ---
# App registered at https://dev.twitch.tv/console (Client Credentials flow -
# no OAuth redirect needed). Leave empty to disable: /creators/ still works,
# just without live-status data.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# In-process poller (twitch_integration/scheduler.py) that detects a creator
# going live, to fire a Discord announcement (see discord_bot app below).
# Set to 0 to disable.
TWITCH_LIVE_POLL_INTERVAL_MINUTES=5

# --- Discord bot bridge (discord_bot app) ---
# The org's Discord bot is a separate deployment (bot-plattform repo) reached
# only via Redis pub/sub - not a REST API. In production this points at the
# `redis` container from that other deployment, already reachable over the
# shared `goalkeeper_prod_network` Docker network both stacks join (see
# docker-compose.yml). Defaults match bot-plattform's own shared/config.py.
REDIS_HOST=redis
REDIS_PORT=6379

# --- Transactional email (account-activated / password-reset, users/emails.py) ---
# Leave EMAIL_HOST empty to just log emails to the console (default, no setup
# needed for local dev). Any SMTP provider works, e.g. a Gmail account with
# an App Password, or a free tier like Brevo (300 emails/day).
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Punishers Germany <no-reply@punishersgermany.de>
